{
  "name": "@cloud_cost_analyzer/be",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "prepare": "npm run build:packages",
    "build:env": "node scripts/build-env.mjs",
    "build:db": "node scripts/build-db.mjs",
    "build:packages": "npm run build:env && npm run build:db && node scripts/prepare.mjs",
    "build": "npm run build:packages && prisma generate && node scripts/bundle.mjs",
    "vercel-build": "npm run build",
    "start": "node dist/server.js",
    "lint": "eslint src"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.729.0",
    "@aws-sdk/client-cost-explorer": "^3.729.0",
    "@aws-sdk/client-ec2": "^3.729.0",
    "@aws-sdk/client-rds": "^3.729.0",
    "@aws-sdk/client-s3": "^3.729.0",
    "@aws-sdk/client-sts": "^3.1027.0",
    "@cloud_cost_analyzer/db": "file:packages/db",
    "@cloud_cost_analyzer/env": "file:packages/env",
    "@prisma/adapter-pg": "7.4.2",
    "pg": "^8.16.3",
    "@google/generative-ai": "^0.24.1",
    "@langchain/core": "^1.1.42",
    "@langchain/google-genai": "^2.1.29",
    "@langchain/groq": "^1.2.0",
    "@prisma/client": "7.4.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.3.5",
    "ms": "^2.1.3",
    "prisma": "7.4.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@cloud_cost_analyzer/config": "file:packages/config",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.11",
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.9",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
