{
    "extends": "@cloud_cost_analyzer/config/tsconfig.base.json",
    "compilerOptions": {
        "moduleResolution": "bundler",
        "outDir": "dist",
        "baseUrl": ".",
        "rootDir": "src",
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}